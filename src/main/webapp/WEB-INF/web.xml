<?xml version="1.0" encoding="UTF-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════════════╗
  ║  TechImport Perú — Deployment Descriptor (web.xml)                 ║
  ║                                                                    ║
  ║  Versión de Servlet: 4.0 (compatible con Tomcat 9)                 ║
  ║                                                                    ║
  ║  Contenido:                                                        ║
  ║    1. Display name y descripción                                   ║
  ║    2. Filtro de codificación de caracteres (UTF-8)                 ║
  ║    3. Servlet: UsuarioController (/usuario/*)                      ║
  ║    4. Archivo de bienvenida: index.jsp                             ║
  ║    5. Configuración de sesión (30 minutos)                         ║
  ║    6. Páginas de error personalizadas (404 y 500)                  ║
  ╚══════════════════════════════════════════════════════════════════════╝
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  Identificación de la aplicación                               -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <display-name>TechImport Perú</display-name>
    <description>
        Plataforma e-commerce para importación y venta de productos
        tecnológicos internacionales. Proyecto académico — UTP.
    </description>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  Filtro: CharacterEncodingFilter                               -->
    <!--  Asegura que TODAS las peticiones y respuestas usen UTF-8.    -->
    <!--  Esto previene problemas con caracteres especiales (ñ, á, é)  -->
    <!--  comunes en el idioma español.                                -->
    <!-- ═══════════════════════════════════════════════════════════════ -->




    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  Archivo de bienvenida                                         -->
    <!--  Tomcat carga index.jsp cuando el usuario accede a la raíz.   -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  Configuración de sesión                                       -->
    <!--  Timeout de 30 minutos de inactividad.                        -->
    <!--  Después de 30 min sin actividad, el usuario deberá volver    -->
    <!--  a iniciar sesión.                                            -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  Páginas de error personalizadas                               -->
    <!--  Proporcionan una experiencia de usuario amigable en lugar    -->
    <!--  de los mensajes de error genéricos de Tomcat.                -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Error 404: Recurso no encontrado -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/vistas/errores/404.jsp</location>
    </error-page>

    <!-- Error 500: Error interno del servidor -->
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/vistas/errores/500.jsp</location>
    </error-page>

</web-app>
